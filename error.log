from sympy import primerange
def is_multiply_prime(a):
    """Check if the given number is the product of exactly three prime numbers."""
    if a < 30:  # The smallest product of three distinct primes is 30
        return False
    
    # Generate a list of all prime numbers less than 100
    primes = list(primerange(1, 100))
    
    # Check all products of three primes (allowing repetition)
    for combo in product(primes, repeat=3):
        if combo[0] * combo[1] * combo[2] == a:
            return True
            
    return False.
