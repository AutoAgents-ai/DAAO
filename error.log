 Solution: def starts_one_ends(n):
    if n == 1:
        # For n = 1, the only 1-digit number that starts or ends with 1 is 1 itself.
        return 1
    
    # Count of n-digit numbers that start with 1
    start_with_1 = 10**(n-1)
    
    # Count of n-digit numbers that end with 1
    end_with_1 = 10**(n-1)
    
    # Count of n-digit numbers that start and end with 1
    start_and_end_with_1 = 10**(n-2)
    
    # Total count
    total_count = start_with_1 + end_with_1 - start_and_end_with_1
    
    return total_count.
