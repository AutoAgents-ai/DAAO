 Solution: def max_fill(grid, capacity):
    import math
    
    # Step 1: Count the total units of water
    total_units_of_water = sum(sum(row) for row in grid)
    
    # Step 2: Calculate the number of bucket lowerings
    # We use math.ceil to round up the division result
    num_lowerings = math.ceil(total_units_of_water / capacity)
    
    return num_lowerings.
