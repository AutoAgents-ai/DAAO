 Solution: def is_nested(string):
    '''
    Determine if the input string of square brackets contains a valid subsequence
    where at least one bracket is nested.

    Parameters:
    string (str): A string containing only '[' and ']'.

    Returns:
    bool: True if there is a valid nested subsequence, False otherwise.
    '''
    
    # Initialize counters for open brackets and the current depth of nesting
    open_count = 0
    max_depth = 0
    
    for char in string:
        if char == '[':
            open_count += 1
            max_depth += 1  # Increase depth for each opening bracket
        elif char == ']':
            if open_count == 0:
                # More closing brackets than opening brackets
                return False
            open_count -= 1
            max_depth -= 1  # Decrease depth for each closing bracket
        
        # If we have more than one level of nesting, we can return True early
        if max_depth > 1:
            return True
    
    # After processing all characters, check if we have balanced brackets
    # and if we have at least one level of nesting
    return open_count == 0 and max_depth > 0.
