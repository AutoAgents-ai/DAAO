 Solution: def match_parens(lst):
    s1, s2 = lst[0], lst[1]
    
    # Count parentheses in both strings
    open1 = s1.count('(')
    close1 = s1.count(')')
    open2 = s2.count('(')
    close2 = s2.count(')')
    
    # Check the first concatenation: s1 + s2
    balance1 = open1 - close1
    balance2 = open2 - close2
    
    # Check if s1 + s2 can be balanced
    if balance1 + balance2 >= 0 and open1 >= close2:
        return 'Yes'
    
    # Check the second concatenation: s2 + s1
    if balance2 + balance1 >= 0 and open2 >= close1:
        return 'Yes'
    
    return 'No'.
