 Solution: def max_fill(grid, capacity):
    total_water = 0
    
    # Count the total number of 1s in the grid
    for row in grid:
        total_water += sum(row)
    
    # If there's no water, no need to lower the buckets
    if total_water == 0:
        return 0
    
    # Calculate the number of times we need to lower the buckets
    # We use math.ceil to round up the division
    import math
    return math.ceil(total_water / capacity).
