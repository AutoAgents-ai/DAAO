    '''
    Determine if the input string of square brackets contains a valid subsequence
    with at least one nested bracket.

    Parameters:
    string (str): A string containing only '[' and ']'.

    Returns:
    bool: True if there is a valid nested subsequence, False otherwise.
    '''
    
    # Initialize counters for open and close brackets
    open_count = 0
    nested_found = False
    
    for char in string:
        if char == '[':
            open_count += 1
            # If we have more than one open bracket, we can potentially have nesting
            if open_count > 1:
